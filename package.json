{
  "name": "fabrique",
  "version": "2.0.5",
  "type": "module",
  "main": "src/cli/cli.ts",
  "bin": "src/cli/cli.ts",
  "scripts": {
    "=== FB: DEV ===": "",
    "fb:run": "node src/cli/cli.ts",
    "fb:link": "npm link",
    "=== FB: BUILD ===": "",
    "fb:build": "fabrique build",
    "=== FB: CODE QUALITY ===": "",
    "fb:format": "yarn fb:format:fix",
    "fb:format:check": "prettier --check --ignore-unknown --config .prettierrc \"./**/*.{js,jsx,ts,tsx,html,css,scss,json,md}\"",
    "fb:format:fix": "prettier --write --ignore-unknown --config .prettierrc \"./**/*.{js,jsx,ts,tsx,html,css,scss,json,md}\"",
    "fb:check": "yarn fb:check:types && yarn fb:format:check",
    "fb:check:types": "tsc -p tsconfig.json --noEmit",
    "=== FB: CI ===": "",
    "fb:ci:release": "fabrique ci release"
  },
  "description": "CLI to build a library",
  "keywords": [],
  "author": "Valentin Richard",
  "license": "MIT",
  "access": "public",
  "repository": {
    "type": "git",
    "url": "https://github.com/lifaon74/fabrique"
  },
  "packageManager": "yarn@4.17.0",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  }
}
